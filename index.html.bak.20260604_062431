// ═══ RENDER COURSE DOCUMENTS ═══
async function loadCourseDocs(folderPath) {
  try {
    const r = await fetch(API + '/second-brain/documents');
    const data = await r.json();
    const matches = data.drive_files.filter(f => f.folder && f.folder.includes(folderPath));
    if (!matches.length) return '<p style="color:var(--dim)">No documents found in this folder.</p>';
    return `<table class="doc-table">
      <thead><tr><th>File</th><th>Folder</th><th>Modified</th></tr></thead>
      <tbody>${matches.map(f => `<tr>
        <td>📄 ${f.name}</td>
        <td><span class="doc-folder">${f.folder}</span></td>
        <td style="color:var(--dim);font-size:11px">${f.modified ? new Date(f.modified).toLocaleDateString('en-GB') : ''}</td>
      </tr>`).join('')}</tbody></table>`;
  } catch(e) { return '<p style="color:var(--dim)">Failed to load documents.</p>'; }
}

