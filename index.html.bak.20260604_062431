          ? start.toLocaleDateString('en-GB', {weekday:'short',day:'numeric',month:'short'})
          : start.toLocaleDateString('en-GB', {weekday:'short',day:'numeric',month:'short'}) + ' · ' + start.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit'});
