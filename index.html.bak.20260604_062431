// ═══ 2ND BRAIN MODAL ═══
async function renderBrainModal() {
  try {
    const r = await fetch(API + '/second-brain/documents');
    const data = await r.json();
    
    const driveHtml = data.drive_files.map(f => `<tr>
      <td>📄 ${f.name}</td>
      <td><span class="doc-folder">${f.folder}</span></td>
      <td style="color:var(--dim);font-size:11px">${f.modified ? new Date(f.modified).toLocaleDateString('en-GB') : ''}</td>
    </tr>`).join('');

    const brainHtml = (data.brain_files||[]).slice(0,20).map(f => `<tr>
      <td>${f.title || f.name}</td>
      <td>${(f.frameworks||[]).slice(0,2).map(fw => `<span style="display:inline-block;margin:1px;padding:1px 6px;border-radius:6px;font-size:9px;background:rgba(59,130,246,0.1);color:#60a5fa">${fw}</span>`).join('')}</td>
      <td style="color:var(--dim);font-size:11px">${f.size ? (f.size/1024).toFixed(1)+'k' : ''}</td>
    </tr>`).join('');

    return `
      <div style="display:flex;gap:10px;margin-bottom:16px">
        <button class="btn btn-gold" onclick="window.open('https://capture.sasin.cfoth.ai','_blank')">🧠 Open Full 2nd Brain</button>
      </div>
      <h4 style="margin-bottom:8px">📁 Google Drive (${data.drive_count} files)</h4>
      <table class="doc-table"><thead><tr><th>File</th><th>Folder</th><th>Modified</th></tr></thead>
      <tbody>${driveHtml || '<tr><td colspan="3" style="color:var(--dim)">No Drive files synced</td></tr>'}</tbody></table>
      
      <h4 style="margin:20px 0 8px">🧠 2nd Brain (${data.brain_count} documents)</h4>
      <table class="doc-table"><thead><tr><th>Document</th><th>Frameworks</th><th>Size</th></tr></thead>
      <tbody>${brainHtml || '<tr><td colspan="3" style="color:var(--dim)">No documents processed</td></tr>'}</tbody></table>
    `;
  } catch(e) {
    return '<p style="color:var(--dim)">Brain data unavailable.</p>';
  }
}

