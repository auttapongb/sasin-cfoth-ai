// ─── Tab Switching ────────────────────────────────
function switchTab(tab) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    const tabId = 'tab' + tab.charAt(0).toUpperCase() + tab.slice(1);
    const el = document.getElementById(tabId);
    if (el) el.classList.add('active');
    // Hide all views
    ['captureView','chatView','brainView','briefsView','flashcardsView','quizzesView','audioView','casesView'].forEach(id => {
        const v = document.getElementById(id);
        if (!v) return;
        if (id === 'chatView') v.classList.toggle('active', tab === 'chat');
        else v.style.display = (id === tab + 'View' || (tab==='chat' && id==='chatView') || (tab==='brain' && id==='brainView')) ? '' : 'none';
    });
    // Fix: explicit view visibility
    document.getElementById('captureView').style.display = tab === 'capture' ? '' : 'none';
    document.getElementById('chatView').classList.toggle('active', tab === 'chat');
    document.getElementById('brainView').style.display = tab === 'brain' ? 'flex' : 'none';
    document.getElementById('briefsView').style.display = tab === 'briefs' ? 'flex' : 'none';
    document.getElementById('flashcardsView').style.display = tab === 'flashcards' ? 'flex' : 'none';
    document.getElementById('quizzesView').style.display = tab === 'quizzes' ? 'flex' : 'none';
    document.getElementById('audioView').style.display = tab === 'audio' ? 'flex' : 'none';
    document.getElementById('casesView').style.display = tab === 'cases' ? 'flex' : 'none';
    // Show/hide capture controls
    const isCapture = tab === 'capture';
    document.getElementById('slideStrip').style.display = isCapture ? '' : 'none';
    document.querySelector('.bottombar').style.display = isCapture ? '' : 'none';
    if (tab === 'chat') document.getElementById('chatInput').focus();
    if (tab === 'brain') { 
        document.getElementById('brainView').style.display = 'flex';
        if (!window._brainGraphInited) { 
            window._brainGraphInited = true; 
            // Wait until brain view is actually visible with dimensions
            setTimeout(() => {
                const v = document.getElementById('brainGraphView');
                if (v) v.style.display = 'block';
                initBrainGraph();
            }, 200);
        }
    }
    if (tab === 'briefs') loadBriefs();
    if (tab === 'flashcards') { loadFlashcardStats(); loadFlashcardsList(); }
    if (tab === 'quizzes') loadQuizzes();
    if (tab === 'audio') loadAudioOverviews();
    if (tab === 'cases') loadCases();
}

