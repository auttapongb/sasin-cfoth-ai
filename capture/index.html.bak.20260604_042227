<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Sasin Lecture Capture — Two-Box Study</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
<script src="https://d3js.org/d3.v7.min.js"></script>
<style>
:root {
    --gold: #C9A84C; --gold-light: #E8D48B;
    --bg: #0A0A14; --card: #141428; --border: #252540;
    --text: #D8D8E8; --dim: #7A7A9A;
    --recording: #E85D3A; --success: #4CAF50; --blue: #3B82F6;
    --box1-accent: #3B82F6; --box2-accent: #C9A84C;
    --box1-bg: #0D1117; --box2-bg: #111118;
}
* { margin:0; padding:0; box-sizing:border-box; }
body {
    font-family: 'Inter', sans-serif;
    background: var(--bg); color: var(--text);
    height: 100vh; overflow: hidden;
    display: flex; flex-direction: column;
}

/* ── Top Bar ── */
.topbar {
    display: flex; align-items: center; gap: 12px;
    padding: 8px 16px; background: var(--card);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0; z-index: 10;
}
.topbar .logo { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--gold); }
.topbar .logo span { font-size: 0.65rem; color: var(--dim); font-family: 'Inter', sans-serif; margin-left: 4px; }
.status-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--success); flex-shrink: 0; }
.status-dot.recording { background: var(--recording); animation: dotPulse 1s infinite; }
@keyframes dotPulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
.status-text { font-size: 0.75rem; color: var(--dim); }
.timer { margin-left: auto; font-family: monospace; font-size: 0.9rem; color: var(--gold); }
.btn-sm {
    padding: 6px 14px; border-radius: 16px; border: 1px solid var(--border);
    background: transparent; color: var(--text); font-size: 0.7rem;
    font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif;
    transition: all 0.15s; white-space: nowrap;
}
.btn-sm:hover { border-color: var(--gold); color: var(--gold); }
.btn-sm.primary { background: var(--recording); border-color: var(--recording); color: white; }
.btn-sm.primary:hover { opacity: 0.9; }
.btn-sm.save { border-color: var(--gold); color: var(--gold); }
.btn-sm.second-brain { border-color: #7C3AED; color: #A78BFA; }
.btn-sm.second-brain:hover { border-color: #A78BFA; background: rgba(124,58,237,0.1); }
.btn-sm.second-brain.uploading { opacity: 0.6; pointer-events: none; animation: dotPulse 1s infinite; }

/* ── Tabs ── */
.tabs { display: flex; gap: 2px; margin: 0 8px; overflow-x: auto; flex-shrink: 0; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
.tab {
    padding: 5px 14px; border: 1px solid var(--border); border-radius: 8px 8px 0 0;
    background: transparent; color: var(--dim); font-size: 0.72rem;
    font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif;
    transition: all 0.15s; border-bottom: none;
}
.tab:hover { color: var(--text); border-color: var(--gold); }
.tab.active { color: var(--gold); border-color: var(--gold); background: rgba(201,168,76,0.06); }

/* ── Tab View Containers ── */
#captureView { display: flex; flex-direction: column; flex: 1; min-height: 0; overflow: hidden; }
#chatView.chat-view.active { display: flex; flex-direction: column; flex: 1; min-height: 0; }

/* ── Chat View ── */
.chat-view {
    display: none; flex-direction: column; height: 100%;
    background: var(--bg);
}
.chat-view.active { display: flex; }
.chat-messages {
    flex: 1; overflow-y: auto; padding: 12px 16px;
    display: flex; flex-direction: column; gap: 10px;
}
.chat-msg {
    max-width: 85%; padding: 10px 14px; border-radius: 14px;
    font-size: 0.85rem; line-height: 1.5; animation: fadeIn 0.2s ease;
}
.chat-msg.user {
    align-self: flex-end; background: rgba(59,130,246,0.15);
    border: 1px solid rgba(59,130,246,0.25); color: var(--text);
    border-bottom-right-radius: 4px;
}
.chat-msg.ai {
    align-self: flex-start; background: var(--card);
    border: 1px solid var(--border); color: var(--text);
    border-bottom-left-radius: 4px;
}
.chat-msg.ai.thinking { opacity: 0.5; }
.chat-input-row {
    display: flex; gap: 8px; padding: 10px 16px;
    background: var(--card); border-top: 1px solid var(--border);
}
.chat-input-row input {
    flex: 1; background: var(--bg); border: 1px solid var(--border);
    border-radius: 20px; padding: 8px 16px; color: var(--text);
    font-size: 0.85rem; font-family: 'Inter', sans-serif; outline: none;
}
.chat-input-row input:focus { border-color: var(--gold); }
.chat-send {
    width: 38px; height: 38px; border-radius: 50%; border: none;
    background: var(--gold); color: var(--bg); font-size: 1rem;
    cursor: pointer; flex-shrink: 0; transition: all 0.15s;
}
.chat-send:hover { background: var(--gold-light); }
.chat-send:disabled { opacity: 0.4; cursor: not-allowed; }
.chat-empty {
    text-align: center; color: var(--dim); padding: 60px 20px;
}
.chat-empty .big-icon { font-size: 2.5rem; margin-bottom: 12px; opacity: 0.4; }

/* ── Main Two-Panel ── */
.main-panels {
    display: flex; flex: 1; overflow: hidden;
    gap: 2px; background: var(--border);
}
.panel {
    flex: 1; display: flex; flex-direction: column;
    background: var(--card); overflow: hidden;
    min-width: 0;
}
.panel-header {
    padding: 10px 14px; font-weight: 700; font-size: 0.8rem;
    display: flex; align-items: center; gap: 8px;
    flex-shrink: 0; letter-spacing: 0.3px;
}
.panel-header .icon { font-size: 1rem; }
.box1 .panel-header { background: rgba(59,130,246,0.1); color: var(--box1-accent); border-bottom: 1px solid rgba(59,130,246,0.2); }
.box2 .panel-header { background: rgba(201,168,76,0.1); color: var(--box2-accent); border-bottom: 1px solid rgba(201,168,76,0.2); }
.panel-body {
    flex: 1; overflow-y: auto; padding: 8px 12px;
    scroll-behavior: smooth;
}
.panel-body::-webkit-scrollbar { width: 4px; }
.panel-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

/* ── Entry Styles ── */
.entry {
    padding: 8px 10px; margin-bottom: 6px;
    border-radius: 8px; animation: fadeIn 0.25s ease;
    font-size: 0.85rem; line-height: 1.5;
    position: relative;
}
@keyframes fadeIn { from { opacity:0; transform:translateY(3px) } to { opacity:1; transform:translateY(0) } }
.entry-time {
    font-size: 0.6rem; color: var(--dim); font-family: monospace;
    margin-bottom: 2px; display: flex; align-items: center; gap: 6px;
}
.entry-time .elapsed { color: var(--gold); font-weight: 600; }
.entry-latest { border-left: 2px solid var(--gold); padding-left: 10px; }
.entry-latest .entry-text { color: #fff; }

/* Box 1 entries */
.box1 .entry { background: rgba(59,130,246,0.04); border: 1px solid rgba(59,130,246,0.08); }
.box1 .entry-text { color: var(--text); white-space: pre-wrap; word-break: break-word; }
.box1 .entry-slide { border: 1px dashed var(--border); padding: 6px; text-align: center; }
.box1 .entry-slide img { max-width: 100%; max-height: 200px; border-radius: 6px; cursor: pointer; }
.box1 .entry-slide .slide-label { font-size: 0.65rem; color: var(--dim); margin-top: 4px; }

/* Box 2 entries */
.box2 .entry { background: rgba(201,168,76,0.04); border: 1px solid rgba(201,168,76,0.08); }
.box2 .entry-text { color: var(--text); }
.box2 .entry-insight { border-left: 2px solid var(--gold); padding-left: 10px; }
.box2 .entry-slide-analysis { }
.box2 .entry-slide-analysis .slide-text { font-size: 0.8rem; color: var(--dim); margin-bottom: 8px; }
.box2 .entry-slide-analysis .qa { margin-bottom: 6px; }
.box2 .entry-slide-analysis .q { color: var(--gold-light); font-weight: 600; font-size: 0.8rem; }
.box2 .entry-slide-analysis .a { color: var(--text); font-size: 0.8rem; padding-left: 10px; border-left: 1px solid var(--border); }
.box2 .entry-slide-analysis .summary { font-style: italic; color: var(--dim); font-size: 0.78rem; margin-bottom: 6px; }
.box2 .entry-slide-analysis .explanation { color: var(--text); font-size: 0.82rem; line-height: 1.6; }

.empty-state {
    text-align: center; color: var(--dim); padding: 40px 20px;
    font-size: 0.85rem; line-height: 1.6;
}
.empty-state .big-icon { font-size: 2rem; margin-bottom: 10px; opacity: 0.5; }

/* ── Slide Strip ── */
.slide-strip {
    display: flex; gap: 6px; overflow-x: auto;
    padding: 8px 0; min-height: 50px; align-items: center;
    flex-shrink: 0; border-top: 1px solid var(--border);
    margin: 0 12px;
}
.slide-strip:empty { min-height:0; padding:0; border:none; }
.slide-thumb {
    flex-shrink: 0; width: 48px; height: 48px; border-radius: 6px;
    background-size: cover; background-position: center;
    border: 1px solid var(--border); cursor: pointer;
    transition: all 0.15s; position: relative;
}
.slide-thumb:hover { border-color: var(--blue); transform: scale(1.05); }
.slide-thumb .badge {
    position: absolute; top: -5px; right: -5px;
    font-size: 0.5rem; padding: 1px 5px; border-radius: 8px;
    font-weight: 700; color: white;
}
.badge-useful { background: var(--box2-accent); }
.badge-raw { background: var(--box1-accent); }

/* ── Bottom Controls ── */
.bottombar {
    display: flex; gap: 8px; padding: 8px 16px;
    background: var(--card); border-top: 1px solid var(--border);
    align-items: center; flex-shrink: 0;
}
.btn-record {
    height: 44px; padding: 0 20px; border-radius: 22px; border: none;
    font-size: 0.9rem; font-weight: 600; cursor: pointer;
    font-family: 'Inter', sans-serif; display: flex; align-items: center; gap: 6px;
    transition: all 0.2s;
}
.btn-record.start { background: var(--recording); color: white; flex: 1; box-shadow: 0 2px 12px rgba(232,93,58,0.3); }
.btn-record.start:hover { transform: translateY(-1px); }
.btn-record.recording { background: transparent; border: 2px solid var(--recording); color: var(--recording); flex: 1; animation: borderPulse 1.5s infinite; }
@keyframes borderPulse { 0%,100%{border-color:var(--recording)} 50%{border-color:rgba(232,93,58,0.3)} }
.btn-slide {
    width: 44px; height: 44px; border-radius: 22px; border: 1px solid var(--blue);
    background: transparent; color: var(--blue); font-size: 1.2rem;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all 0.15s; flex-shrink: 0;
}
.btn-slide:hover { background: rgba(59,130,246,0.1); }
.btn-slide:active { transform: scale(0.94); }
.btn-slide.pdf-upload { border-color: #7C3AED; color: #A78BFA; }
.btn-slide.pdf-upload:hover { background: rgba(124,58,237,0.15); }
.btn-slide.pdf-upload.uploading { animation: dotPulse 1s infinite; pointer-events: none; opacity: 0.5; }

/* Toast */
.toast {
    position: fixed; bottom: 70px; left: 50%; transform: translateX(-50%);
    padding: 10px 20px; border-radius: 10px; font-size: 0.8rem;
    font-weight: 500; z-index: 100; animation: slideUp 0.3s ease;
    max-width: 90vw; text-align: center;
}
.toast.error { background: var(--recording); color: white; }
.toast.info { background: var(--card); color: var(--gold); border: 1px solid var(--gold); }
@keyframes slideUp { from { opacity:0; transform:translateX(-50%) translateY(15px) } to { opacity:1; transform:translateX(-50%) translateY(0) } }

/* Mobile responsive */
.month-badge {
    font-size: 0.6rem; color: var(--gold); font-weight: 700;
    padding: 4px 0; margin-top: 10px; border-top: 1px solid var(--border);
    letter-spacing: 0.5px;
}
.month-badge:first-child { margin-top: 0; border-top: none; }
#sessionSearch:focus { border-color: var(--gold) !important; }
@media (max-width: 768px) {
    .main-panels { flex-direction: column; }
    .panel { flex: none; height: 50%; }
    .topbar { padding: 6px 10px; }
    .bottombar { padding: 6px 10px; }
    .panel-body { padding: 6px 8px; }
    .entry { font-size: 0.8rem; padding: 6px 8px; }
}
/* ── Session Title ── */
.session-title {
    font-size: 0.75rem; color: var(--gold-light); font-weight: 500;
    margin: 0 8px; padding: 2px 10px; border-radius: 10px;
    background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.2);
    cursor: pointer; max-width: 180px; overflow: hidden;
    text-overflow: ellipsis; white-space: nowrap; transition: all 0.15s;
}
.session-title:hover { background: rgba(201,168,76,0.2); }
.session-title:empty { display: none; }

/* ── Load Modal ── */
.modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.7);
    display: flex; align-items: center; justify-content: center;
    z-index: 1000; animation: fadeIn 0.2s ease;
}
.modal-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 14px; width: 90vw; max-width: 480px;
    max-height: 70vh; display: flex; flex-direction: column;
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
}
.modal-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 18px; border-bottom: 1px solid var(--border);
    font-weight: 600; font-size: 0.9rem; color: var(--gold);
}
.modal-close {
    background: none; border: none; color: var(--dim); font-size: 1.1rem;
    cursor: pointer; padding: 4px 8px; border-radius: 6px;
}
.modal-close:hover { color: var(--text); background: rgba(255,255,255,0.05); }
.modal-body { padding: 8px; overflow-y: auto; flex: 1; }
.session-list-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px; border-radius: 10px; cursor: pointer;
    transition: all 0.12s; border: 1px solid transparent;
    margin-bottom: 2px;
}
.session-list-item:hover { background: rgba(201,168,76,0.06); border-color: var(--border); }
.session-list-item .sli-title { font-weight: 600; font-size: 0.85rem; color: var(--text); }
.session-list-item .sli-meta { font-size: 0.65rem; color: var(--dim); margin-top: 2px; }
.session-list-item .sli-count {
    font-size: 0.7rem; color: var(--gold); background: rgba(201,168,76,0.1);
    padding: 3px 8px; border-radius: 10px; white-space: nowrap;
}

.month-badge {
    font-size: 0.6rem; color: var(--gold); font-weight: 700;
    padding: 4px 0; margin-top: 10px; border-top: 1px solid var(--border);
    letter-spacing: 0.5px;
}
.month-badge:first-child { margin-top: 0; border-top: none; }
#sessionSearch:focus { border-color: var(--gold) !important; }
@media (max-width: 768px) {
    .modal-card { width: 95vw; max-height: 80vh; }
    .session-title { max-width: 120px; font-size: 0.7rem; }
}
/* ── v5: New Tab Views ── */
.tab-view {
    display: none; flex-direction: column; flex: 1; min-height: 0; overflow-y: auto;
}
.tab-view.active { display: flex; }
#brainView, #briefsView, #flashcardsView, #quizzesView, #audioView, #casesView {
    background: var(--bg);
}
#brainGraph { min-height: 500px; min-width: 100%; }
/* Brain tab toolbar + sub-tabs */
#brainToolbar {
  position: absolute; top: 8px; left: 12px; right: 12px; z-index: 20;
  display: flex; align-items: center; gap: 10px;
  background: rgba(20,20,40,0.95); border: 1px solid var(--border);
  border-radius: 10px; padding: 6px 12px;
}
#brainSyncBtn {
  background: linear-gradient(135deg, #7C3AED, #A78BFA); color: #fff;
  border: none; padding: 5px 14px; border-radius: 6px;
  font-size: 12px; cursor: pointer; font-weight: 600;
  font-family: 'Inter', sans-serif; white-space: nowrap;
}
#brainSyncBtn:hover { opacity: 0.9; }
#brainSyncBtn:disabled { opacity: 0.5; cursor: not-allowed; }
#brainSyncStatus { font-size: 11px; color: var(--dim); }
.brain-subtabs { display: flex; gap: 2px; margin-left: 8px; }
.brain-subtab {
  background: transparent; border: 1px solid transparent;
  color: var(--dim); padding: 5px 12px; border-radius: 6px;
  font-size: 12px; cursor: pointer; font-family: 'Inter', sans-serif;
}
.brain-subtab:hover { color: var(--text); border-color: var(--border); }
.brain-subtab.active {
  color: var(--gold); border-color: var(--gold);
  background: rgba(201,168,76,0.08);
}
.brain-subview { display: none; position: relative; flex: 1; min-height: 400px; margin-top: 48px; }
.brain-subview.active { display: block; min-height: 400px; height: calc(100vh - 160px); }
#brainGraphView.active { height: calc(100vh - 160px); }
/* Brain documents table */
.brain-doc-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.brain-doc-table th { text-align: left; padding: 8px 10px; color: var(--dim); border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; }
.brain-doc-table td { padding: 8px 10px; border-bottom: 1px solid rgba(148,163,184,0.05); }
.brain-doc-table tr:hover { background: rgba(59,130,246,0.03); }
.brain-doc-name { color: var(--text); max-width: 260px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.brain-doc-del { background: rgba(232,93,58,0.12); color: #E85D3A; border: none; padding: 3px 10px; border-radius: 4px; font-size: 11px; cursor: pointer; }
.brain-doc-del:hover { background: rgba(232,93,58,0.25); }
#brainDocsView { padding: 8px 16px; overflow-y: auto; max-height: calc(100vh - 140px); }
#brainDocsSearch { width: 100%; max-width: 300px; background: rgba(20,20,40,0.9); border: 1px solid var(--border); border-radius: 8px; padding: 7px 12px; color: var(--text); font-size: 12px; outline: none; font-family: 'Inter',sans-serif; margin-bottom: 16px; }
.brain-section { margin-bottom: 24px; }
.brain-section h4 { font-size: 13px; color: var(--dim); margin-bottom: 8px; }

/* ── Flashcards ── */
#flashcardCard {
    perspective: 1000px;
}
#flashcardCard:hover {
    transform: scale(1.02);
}

/* ── Modal Overlay ── */
.modal-overlay {
    display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.7); z-index: 100;
    align-items: center; justify-content: center;
}
.modal-card {
    background: var(--card); border: 1px solid var(--gold);
    border-radius: 16px; padding: 24px; max-width: 500px; width: 90%;
    max-height: 80vh; overflow-y: auto;
}
.modal-header {
    display: flex; align-items: center; gap: 12px; margin-bottom: 16px;
}
.modal-header span { color: var(--gold); font-weight: 600; }
.modal-close {
    margin-left: auto; background: none; border: none;
    color: var(--dim); font-size: 1.2rem; cursor: pointer;
}
.modal-body { max-height: 60vh; overflow-y: auto; }

/* ── Responsive Tab Bar ── */
@media (max-width: 900px) {
    .tabs { flex-wrap: wrap; gap: 1px; }
    .tab { font-size: 0.65rem; padding: 4px 8px; }
}
@media (max-width: 600px) {
    .topbar { flex-wrap: wrap; gap: 6px; }
    .topbar .logo { font-size: 0.9rem; }
    .btn-sm { font-size: 0.65rem; padding: 4px 10px; }
    #flashcardCard { min-height: 180px; padding: 20px; }
    #flashcardFront { font-size: 1rem; }
}
</style>
</head>
<body>

<!-- ═══ TOP BAR ═══ -->
<div class="topbar">
    <div class="status-dot connected" id="statusDot"></div>
    <span class="status-text" id="statusText">Ready</span>
    <div class="logo">Sasin <span>EMBA 2026</span></div>
    <div class="tabs">
        <button class="tab active" id="tabCapture" onclick="switchTab('capture')">📝 Capture</button>
        <button class="tab" id="tabChat" onclick="switchTab('chat')">💬 Chat</button>
        <button class="tab" id="tabBrain" onclick="switchTab('brain')">🧠 2nd Brain</button>
        <button class="tab" id="tabBriefs" onclick="switchTab('briefs')">📋 Briefs</button>
        <button class="tab" id="tabFlashcards" onclick="switchTab('flashcards')">🃏 Cards</button>
        <button class="tab" id="tabQuizzes" onclick="switchTab('quizzes')">📝 Quiz</button>
        <button class="tab" id="tabAudio" onclick="switchTab('audio')">🎧 Audio</button>
        <button class="tab" id="tabCases" onclick="switchTab('cases')">📊 Cases</button>
    </div>
    <span class="session-title" id="sessionTitle" onclick="renameSession()" title="Click to rename">New Session</span>
    <span class="timer" id="timer">00:00</span>
    <button class="btn-sm" onclick="loadSessions()" title="Load past session">📂 Load</button>
    <button class="btn-sm save" onclick="saveCurrentSession()">💾 Save</button>
    <button class="btn-sm" onclick="newSession()">✨ New</button>
    <button class="btn-sm second-brain" id="btnSecondBrain" onclick="pushToSecondBrain()" title="Upload transcript to Second Brain">🧠 2nd Brain</button>
    <button class="btn-sm" onclick="extractActions()" title="Extract action items">✅ Actions</button>
    <button class="btn-sm" onclick="showSchedule()" title="Study schedule">📅 Schedule</button>
</div>

<!-- ═══ CAPTURE VIEW ═══ -->
<div id="captureView" class="tab-view active">
<!-- ═══ TWO-PANEL ═══ -->
<div class="main-panels">
    <!-- Box 1: Transcript -->
    <div class="panel box1">
        <div class="panel-header">
            <span class="icon">📝</span> Transcript
            <span style="font-size:0.65rem;color:var(--dim);margin-left:auto" id="box1Count">0 entries</span>
        </div>
        <div class="panel-body" id="box1Body">
