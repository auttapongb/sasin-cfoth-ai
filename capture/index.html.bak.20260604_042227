<!-- ═══ SCRIPTS ═══ -->
<script>
const API = 'https://capture.sasin.cfoth.ai';
let isRecording = false, mediaRecorder = null, startTime = 0, timerInterval = null;
let chunkQueue = [], queueProcessing = false;
let chunkIndex = 0, sessionId = '', totalWords = 0;
let box1Entries = 0, box2Entries = 0;
let lastTranscript = ''; // for co-learner context
let colearnerBusy = false;
let lastColearnerTime = 0;
const COLEARNER_COOLDOWN_MS = 30000; // 30 seconds between insights

// ─── Session ──────────────────────────────────────
async function startSession(title) {
    title = title || '';
    const resp = await fetch(`${API}/sessions`, {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: 'title=' + encodeURIComponent(title) + '&tags=live'
    });
    const data = await resp.json();
    sessionId = data.session_id;
    document.getElementById('sessionTitle').textContent = data.title || title;
    box1Entries = 0; box2Entries = 0;
    document.getElementById('box1Body').innerHTML = '';
    document.getElementById('box2Body').innerHTML = '';
    document.getElementById('slideStrip').innerHTML = '';
    updateCounts();
    toast('Session: ' + (data.title || title), 'info');
    return sessionId;
}

async function saveCurrentSession() {
    if (!sessionId) { toast('No active session', 'error'); return; }
    downloadTranscript();
}

async function newSession() {
    if (isRecording) { toast('Stop recording first', 'error'); return; }
    const title = prompt('Lecture title:', '');
    if (title === null) return; // cancelled
    await startSession(title || undefined);
}

async function loadSessions() {
    if (isRecording) { toast('Stop recording first', 'error'); return; }
    try {
        const resp = await fetch(`${API}/sessions`);
        const data = await resp.json();
        window._allSessions = data.sessions || []; const sessions = window._allSessions;
        const body = document.getElementById('loadModalBody');

        if (sessions.length === 0) {
            body.innerHTML = '<div class="empty-state"><div class="big-icon">📭</div>No saved sessions yet.<br><span style="font-size:0.7rem">Record a lecture first!</span></div>';
        } else {
            let currentMonth = '';
            body.innerHTML = sessions.map(s => {
                const title = s.title || s.id;
                const d = new Date(s.updated_at);
                const date = d.toLocaleDateString('en-GB', {day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});
                const month = d.toLocaleDateString('en-GB', {month:'long',year:'numeric'});
                const count = s.entry_count || 0;
                const preview = (s.preview || '').substring(0, 80);
                let icon = '📝';
                const ti = (s.tags || '') + ' ' + (s.title || '');
                if (/pdf/i.test(ti) || /\.pdf$/i.test(s.title||'')) icon = '📄';
                else if (/slide/i.test(ti)) icon = '📸';
                else if (/live/i.test(s.tags||'') || count > 5) icon = '🎙️';
                const escTitle = escapeHtml(title).replace(/'/g, "&#39;");
                const monthHeader = month !== currentMonth ? (currentMonth = month, '<div class="month-badge">' + month + '</div>') : '';
                return monthHeader + '<div class="session-list-item">'
                    + '<div style="flex:1;min-width:0" onclick="selectSession(\'' + s.id + '\',\'' + title.replace(/'/g, "\\'") + '\')">'
                    + '<div class="sli-title">' + icon + ' ' + escapeHtml(title) + '</div>'
                    + '<div class="sli-meta">' + date + (preview ? ' — ' + escapeHtml(preview) : '') + '</div></div>'
                    + '<div style="display:flex;align-items:center;gap:6px;flex-shrink:0">'
                    + '<div class="sli-count">' + count + '</div>'
                    + '<button class="modal-close" onclick="event.stopPropagation();downloadSession(\'' + s.id + '\',\'' + escTitle + '\')" title="Download" style="font-size:0.9rem;padding:2px 6px">📥</button>'
                    + '<button class="modal-close" onclick="event.stopPropagation();deleteSession(\'' + s.id + '\')" title="Delete" style="font-size:0.9rem;padding:2px 6px;color:#E85D3A;">🗑</button>'
                    + '</div></div>';
            }).join('');
        }
        document.getElementById('loadModal').style.display = 'flex';
    const searchEl = document.getElementById('sessionSearch');
    if (searchEl) searchEl.value = '';
    } catch(e) {
        toast('Failed to load sessions: ' + e.message, 'error');
    }
}

async function selectSession(sid, title) {
    closeLoadModal();
    sessionId = sid;
    document.getElementById('sessionTitle').textContent = title || sid;
    try {
        const detail = await fetch(`${API}/sessions/${sid}`);
        const sdata = await detail.json();
        document.getElementById('box1Body').innerHTML = '';
        document.getElementById('box2Body').innerHTML = '';
        document.getElementById('slideStrip').innerHTML = '';
        box1Entries = 0; box2Entries = 0;
        for (const e of sdata.entries) {
            renderSavedEntry(e);
        }
        updateCounts();
        toast('Loaded: ' + title + ' (' + sdata.entry_count + ' entries)', 'info');
    } catch(e) {
        toast('Failed to load session: ' + e.message, 'error');
    }
}

async function downloadSession(sid, title) {
    const a = document.createElement('a');
    a.href = `${API}/sessions/${sid}/download`;
    a.download = (title || 'session').replace(/[^a-zA-Z0-9ก-๙ \-]/g, '_') + '.txt';
    a.click();
    toast('Downloading: ' + (title || sid), 'info');
}

function filterSessions() {
    const q = (document.getElementById('sessionSearch').value || '').toLowerCase();
    const body = document.getElementById('loadModalBody');
    const sessions = window._allSessions || [];
    if (!q) {
        // Re-render all
        const all = body.querySelectorAll('.session-list-item, .month-badge');
        all.forEach(el => el.style.display = '');
        return;
    }
    // Show/hide items
    let visibleMonth = '';
    const items = body.querySelectorAll('.session-list-item');
    const badges = body.querySelectorAll('.month-badge');
    items.forEach((item, i) => {
        const text = item.textContent.toLowerCase();
        const show = text.includes(q);
        item.style.display = show ? '' : 'none';
    });
    // Hide empty month badges
    badges.forEach(badge => {
        let next = badge.nextElementSibling;
        let hasVisible = false;
        while (next && !next.classList.contains('month-badge')) {
            if (next.classList.contains('session-list-item') && next.style.display !== 'none') {
                hasVisible = true;
                break;
            }
            next = next.nextElementSibling;
        }
        badge.style.display = hasVisible ? '' : 'none';
    });
}

function closeLoadModal() {
    document.getElementById('loadModal').style.display = 'none';
}

function renameSession() {
    if (!sessionId) return;
    const current = document.getElementById('sessionTitle').textContent;
    const title = prompt('Rename session:', current);
    if (title === null || title === current) return;
    document.getElementById('sessionTitle').textContent = title;
    // Update title on server
    fetch(`${API}/sessions/${sessionId}/rename`, {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: 'title=' + encodeURIComponent(title)
    }).catch(e => console.error('Rename failed:', e));
    toast('Renamed to: ' + title, 'info');
}

function renderSavedEntry(e) {
    try {
        if (e.box === 'transcript') {
            if (e.content_type === 'slide_image') {
                const meta = JSON.parse(e.metadata || '{}');
                const imgUrl = meta.image_path ? `${API}/slides/${meta.image_path.split('/').pop()}` : '';
                addSlideToBox1(e.timestamp_iso, e.elapsed_sec, imgUrl || `/slides/${meta.image_hash}.jpg`);
            } else {
                addToBox1(e.content, e.timestamp_iso, e.elapsed_sec);
            }
        } else if (e.box === 'colearner') {
            if (e.content_type === 'slide_analysis') {
                const parsed = JSON.parse(e.content);
                addToBox2(parsed, 'slide_analysis', e.timestamp_iso, e.elapsed_sec);
            } else {
                addToBox2(e.content, 'insight', e.timestamp_iso, e.elapsed_sec);
            }
        }
    } catch(err) {
        console.error('Render error:', err, e);
    }
}

// ─── Recording ────────────────────────────────────
async function toggleRecording() {
    if (isRecording) return;
    if (!sessionId) await startSession();
    try {
        const stream = await navigator.mediaDevices.getUserMedia({
            audio: { sampleRate: 16000, channelCount: 1, echoCancellation: true }
        });
                let mimeType = 'audio/webm;codecs=opus';
        if (!MediaRecorder.isTypeSupported(mimeType)) {
            mimeType = 'audio/webm';
            if (!MediaRecorder.isTypeSupported(mimeType)) {
                mimeType = 'audio/mp4';
            }
        }
        mediaRecorder = new MediaRecorder(stream, { mimeType });
        
        // Reset queue for new recording
        chunkQueue = [];
        queueProcessing = false;
        
        async function processQueue() {
            if (queueProcessing || chunkQueue.length === 0) return;
            queueProcessing = true;
            while (chunkQueue.length > 0) {
                const chunk = chunkQueue.shift();
                const form = new FormData();
                form.append('audio', chunk.blob, 'chunk.webm');
                form.append('chunk_index', chunk.index);
                form.append('session_id', sessionId);
                form.append('elapsed_sec', (Date.now() - startTime) / 1000);
                const t0 = Date.now();
                try {
                    const resp = await fetch(`${API}/transcribe`, { method: 'POST', body: form });
                    const data = await resp.json();
                    const lat = Date.now() - t0;
                    if (data.text && data.text.trim()) {
                        addToBox1(data.text.trim(), data.timestamp_iso, data.elapsed_sec || ((Date.now()-startTime)/1000));
                        totalWords += data.text.split(/\s+/).filter(w=>w).length;
                        lastTranscript = data.text.trim();
                        triggerCoLearner(data.text.trim(), '', (Date.now() - startTime) / 1000);
                        document.getElementById('statusText').textContent = `Recording (${chunk.index + 1} chunks)`;
                    } else if (data.error) {
                        console.warn('Chunk', chunk.index, 'STT error:', data.error);
                    }
                } catch(err) {
                    console.error('Chunk', chunk.index, 'failed:', err);
                }
            }
            queueProcessing = false;
        }
        
        mediaRecorder.ondataavailable = (e) => {
            if (!isRecording) return;
            if (e.data.size < 100) return; // lowered from 1000 — quiet audio makes small chunks
            chunkQueue.push({ blob: e.data, index: chunkIndex++ });
            processQueue();
        };
        
        mediaRecorder.start(5000);
        isRecording = true;
        startTime = Date.now();
        chunkIndex = 0;
        totalWords = 0;
        timerInterval = setInterval(updateTimer, 500);
        document.getElementById('btnRecord').className = 'btn-record recording';
        document.getElementById('btnIcon').textContent = '⏺️';
        document.getElementById('btnLabel').textContent = 'Recording...';
        document.getElementById('statusDot').className = 'status-dot recording';
        document.getElementById('statusText').textContent = 'Recording (0 chunks)';
        document.getElementById('btnStop').style.display = 'inline-flex';
        document.getElementById('btnDownload').style.display = 'none';
        mediaRecorder._stream = stream;
        toast('Recording — 5s chunks', 'info');
    } catch(e) {
        toast('Microphone denied: ' + e.message, 'error');
    }
}

async function stopAndSave() {
    if (!isRecording) return;
    if (mediaRecorder) {
        mediaRecorder.stop();
        if (mediaRecorder._stream) mediaRecorder._stream.getTracks().forEach(t => t.stop());
    }
    isRecording = false;
    clearInterval(timerInterval);
    document.getElementById('btnRecord').className = 'btn-record start';
    document.getElementById('btnIcon').textContent = '🎙️';
    document.getElementById('btnLabel').textContent = 'Start Recording';
    document.getElementById('btnStop').style.display = 'none';
    document.getElementById('statusDot').className = 'status-dot recording';
    document.getElementById('statusText').textContent = 'Finishing... (' + chunkQueue.length + ' chunks left)';
    lastColearnerTime = 0;
    
    // Wait for queue to drain (final chunks from stop + any in-flight)
    const maxWait = 30000; // 30s max
    const startWait = Date.now();
    while (chunkQueue.length > 0 || queueProcessing) {
        if (Date.now() - startWait > maxWait) break;
        await new Promise(r => setTimeout(r, 200));
        if (chunkQueue.length > 0 || queueProcessing) {
            document.getElementById('statusText').textContent = 'Finishing... (' + chunkQueue.length + ' left)';
        }
    }
    
    document.getElementById('btnDownload').style.display = 'inline-flex';
    document.getElementById('statusDot').className = 'status-dot connected';
    document.getElementById('statusText').textContent = 'Stopped';

    // Persist to backend
    const elapsed = Math.floor((Date.now() - startTime) / 1000);
    saveToBackend(elapsed);
    toast(`Recording stopped — ${formatTime(elapsed)} captured`, 'info');
}

async function saveToBackend(duration) {
    try {
        const allTranscripts = [];
        document.getElementById('box1Body').querySelectorAll('.entry-text').forEach(e => allTranscripts.push(e.textContent));
        const fullText = allTranscripts.join('\n');
        await fetch(`${API}/save`, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                transcript: fullText,
                word_count: totalWords,
                duration: duration,
                chunks: chunkIndex,
                timestamp: new Date().toISOString(),
                tags: 'lecture'
            })
        });
    } catch(e) {
        console.error('Save failed:', e);
    }
}

function updateTimer() {
    if (!isRecording) return;
    const elapsed = Math.floor((Date.now() - startTime) / 1000);
    const m = Math.floor(elapsed / 60).toString().padStart(2, '0');
    const s = (elapsed % 60).toString().padStart(2, '0');
    document.getElementById('timer').textContent = `${m}:${s}`;
}

