// ─── Box 2: AI Co-Learner ─────────────────────────
function addToBox2(content, type, timestampIso, elapsedSec) {
    const body = document.getElementById('box2Body');
    if (box2Entries === 0) body.innerHTML = '';
    box2Entries++;
    updateCounts();

    const elapsed = elapsedSec ? formatTime(elapsedSec) : '';
    const time = timestampIso ? new Date(timestampIso).toLocaleTimeString() : new Date().toLocaleTimeString();
    const entry = document.createElement('div');
    entry.className = 'entry entry-latest';
    entry.id = `entry-box2-${box2Entries}`;

    if (type === 'insight') {
        entry.innerHTML = `
            <div class="entry-time">
                <span class="elapsed">${elapsed}</span>
                <span>${time} 💡 Insight</span>
            </div>
            <div class="entry-text entry-insight">${escapeHtml(content)}</div>
        `;
    } else if (type === 'slide_analysis') {
        let html = `<div class="entry-time"><span class="elapsed">${elapsed}</span><span>${time} 🔍 Slide Analysis</span></div>`;
        html += '<div class="entry-slide-analysis">';
        if (content.explanation) html += `<div class="explanation">${escapeHtml(content.explanation)}</div>`;
        if (content.summary) html += `<div class="summary">📌 ${escapeHtml(content.summary)}</div>`;
        if (content.text) html += `<div class="slide-text">📄 ${escapeHtml(content.text.substring(0, 300))}${content.text.length>300?'...':''}</div>`;
        if (content.questions && content.questions.length > 0) {
            for (let i = 0; i < content.questions.length; i++) {
                html += `<div class="qa"><div class="q">❓ ${escapeHtml(content.questions[i])}</div>`;
                if (content.answers[i]) html += `<div class="a">→ ${escapeHtml(content.answers[i])}</div>`;
                html += '</div>';
            }
        }
        html += '</div>';
        entry.innerHTML = html;
    } else {
        entry.innerHTML = `
            <div class="entry-time"><span class="elapsed">${elapsed}</span><span>${time}</span></div>
            <div class="entry-text">${escapeHtml(content)}</div>
        `;
    }

    body.appendChild(entry);
    body.scrollTop = body.scrollHeight;

    const prev = body.querySelectorAll('.entry-latest');
    if (prev.length > 1) prev[0].classList.remove('entry-latest');
}

// ─── AI Co-Learner Trigger ────────────────────────
async function triggerCoLearner(transcriptChunk, slideContext, elapsedSec) {
    if (colearnerBusy) return;
    if (!transcriptChunk.trim() && !slideContext.trim()) return;
    // Cooldown: don't fire more than once per 30 seconds
    const now = Date.now();
    if (now - lastColearnerTime < COLEARNER_COOLDOWN_MS) return;
    lastColearnerTime = now;
    colearnerBusy = true;
    document.getElementById('colearnerStatus').textContent = '💭 thinking...';

    try {
        const resp = await fetch(`${API}/co-learner`, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                session_id: sessionId,
                transcript_chunk: transcriptChunk || '',
                slide_context: slideContext || '',
                elapsed_sec: elapsedSec || 0
            })
        });
        const data = await resp.json();
        if (data.insight && data.insight.trim()) {
            addToBox2(data.insight, 'insight', data.timestamp_iso, elapsedSec);
        }
        document.getElementById('colearnerStatus').textContent = '';
    } catch(e) {
        console.error('Co-learner error:', e);
        document.getElementById('colearnerStatus').textContent = '';
    }
    colearnerBusy = false;
}

// ─── PDF Upload ────────────────────────────────────
function uploadPDF() {
    document.getElementById('pdfInput').click();
}

async function handlePDFUpload(input) {
    if (!input.files || !input.files.length) return;
    
    const files = Array.from(input.files);
    const btn = document.getElementById('btnPDF');
    btn.classList.add('uploading');
    
    if (!sessionId) await startSession(files[0].name.replace('.pdf',''));
    
    let success = 0, fail = 0;
    const now = new Date().toISOString();
    
    for (const file of files) {
        const shortName = file.name.length > 20 ? file.name.substring(0,17)+'...' : file.name;
        btn.textContent = '⏳ ' + shortName;
        document.getElementById('statusText').textContent = 'Uploading PDF...';
        const form = new FormData();
        form.append('file', file);
        form.append('file_type', 'pdf');
        form.append('title', file.name.replace('.pdf',''));
        form.append('tags', 'lecture,pdf');
        
        try {
            const resp = await fetch(`${API}/ingest`, { method: 'POST', body: form });
            const data = await resp.json();
            
            if (data.deep_tutor_uploaded && data.text_extracted) {
                success++;
                const title = file.name.replace('.pdf','');
                
                // Box 1: Show extracted text as a transcript entry
                const preview = data.text_extracted.substring(0, 500);
                const fullText = data.text_extracted;
                addToBox1('📄 ' + title + '\n\n' + preview + (fullText.length > 500 ? '\n\n... (full text in Second Brain)' : ''), now, 0);
                
                // Box 2: AI analyzes the PDF content
                triggerCoLearner(fullText.substring(0, 2000), 'Document: ' + title, 0);
                
                toast(title + ' — ' + data.word_count + ' words indexed', 'info');
            } else {
                fail++;
                console.error('PDF upload failed:', file.name, data.error || data);
                toast(file.name + ' failed', 'error');
            }
        } catch(e) {
            fail++;
            console.error('PDF upload error:', file.name, e);
            toast(file.name + ' error: ' + e.message, 'error');
        }
    }
    
    btn.classList.remove('uploading');
    btn.textContent = '📄';
    document.getElementById('statusText').textContent = isRecording ? 'Recording' : 'Ready';
    input.value = '';
}

// ─── Slide Capture ────────────────────────────────
