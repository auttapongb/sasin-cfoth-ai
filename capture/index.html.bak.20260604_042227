    document.getElementById('slideInput').click();
}

async function handleSlideCapture(input) {
    if (!input.files || !input.files[0]) return;
    const file = input.files[0];
    if (!sessionId) await startSession('Slide Capture');
    const elapsedSec = isRecording ? (Date.now() - startTime) / 1000 : 0;
    const form = new FormData();
    form.append('image', file);
    form.append('session_id', sessionId);
    form.append('elapsed_sec', elapsedSec);

    // Show thumbnail with loading state
    const imgUrl = URL.createObjectURL(file);
    const thumbDiv = addSlideThumb(imgUrl, 'processing');
    thumbDiv.classList.add('processing');
    document.getElementById('btnSlide').textContent = '🔍';
    document.getElementById('btnSlide').classList.add('uploading');
    document.getElementById('statusText').textContent = 'Analyzing slide...';

    try {
        const resp = await fetch(`${API}/analyze-slide`, { method: 'POST', body: form });
        const data = await resp.json();

        // Remove processing thumb
        thumbDiv.remove();

        document.getElementById('btnSlide').textContent = '📸';
        document.getElementById('btnSlide').classList.remove('uploading');
        document.getElementById('statusText').textContent = isRecording ? 'Recording' : 'Ready';
        
        if (data.box === 'colearner' && data.analysis) {
            // Useful info → Box 2
            addSlideThumb(`${API}${data.image_url}`, 'useful');
            addToBox2(data.analysis, 'slide_analysis', data.timestamp_iso, elapsedSec);
            // Also trigger co-learner with slide context
            const slideText = data.analysis.text || data.analysis.summary || '';
            if (slideText) {
                triggerCoLearner('', slideText, elapsedSec);
            }
        } else {
            // No useful info → Box 1
            addSlideThumb(`${API}${data.image_url}`, 'raw');
            addSlideToBox1(data.timestamp_iso, elapsedSec, data.image_url);
        }
    } catch(e) {
        console.error('Slide analysis error:', e);
        document.getElementById('btnSlide').textContent = '📸';
        document.getElementById('btnSlide').classList.remove('uploading');
        toast('Slide analysis failed', 'error');
    }

    input.value = '';
}

// ─── Slide Strip ──────────────────────────────────
function addSlideThumb(url, analysisType) {
    // Remove any processing thumb for this URL
    const strip = document.getElementById('slideStrip');
    const existing = strip.querySelectorAll('.slide-thumb.processing');
    existing.forEach(e => e.remove());
    const thumb = document.createElement('div');
    thumb.className = 'slide-thumb';
    thumb.style.backgroundImage = `url(${url})`;
    thumb.onclick = () => window.open(url);
    if (analysisType === 'useful') {
        thumb.innerHTML = '<div class="badge badge-useful">🧠</div>';
    } else if (analysisType === 'raw') {
        thumb.innerHTML = '<div class="badge badge-raw">📝</div>';
    } else if (analysisType === 'processing') {
        // keep it bare for loading state
    }
    strip.appendChild(thumb);
    return thumb;
}

// ─── Helpers ─────────────────────────────────────
function updateCounts() {
    document.getElementById('box1Count').textContent = `${box1Entries} entries`;
    document.getElementById('box2Count').textContent = `${box2Entries} insights`;

    // Remove empty states if entries exist
    if (box1Entries > 0) {
        const empty = document.getElementById('box1Body').querySelector('.empty-state');
        if (empty) empty.remove();
    }
    if (box2Entries > 0) {
        const empty = document.getElementById('box2Body').querySelector('.empty-state');
        if (empty) empty.remove();
    }
}

function formatTime(sec) {
    const m = Math.floor(sec / 60);
    const s = Math.floor(sec % 60);
    return `${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

function toast(msg, type) {
    const el = document.createElement('div');
    el.className = `toast ${type}`;
    el.textContent = msg;
    document.body.appendChild(el);
    setTimeout(() => { el.style.opacity = '0'; setTimeout(() => el.remove(), 300); }, 3000);
}

// ─── Second Brain ─────────────────────────────────
async function pushToSecondBrain() {
    if (!sessionId) { toast('No active session', 'error'); return; }
    
    const allText = [];
    document.getElementById('box1Body').querySelectorAll('.entry-text').forEach(e => allText.push(e.textContent));
    if (!allText.length) { toast('Nothing to upload — record first', 'error'); return; }
    
    const fullTranscript = allText.join('\n\n');
    const title = document.getElementById('sessionTitle').textContent || 'Untitled';
    const btn = document.getElementById('btnSecondBrain');
    btn.classList.add('uploading');
    btn.textContent = '⏳ Uploading...';
    
    try {
        // Create a text file blob and send to second brain
        const blob = new Blob([fullTranscript], {type: 'text/plain'});
        const form = new FormData();
        form.append('file', blob, title.replace(/[^a-zA-Z0-9ก-๙\s]/g, '_') + '.txt');
        form.append('file_type', 'text');
        form.append('title', title);
        form.append('tags', 'lecture,capture');
        
        const resp = await fetch(`${API}/ingest`, {
            method: 'POST',
            body: form
        });
        const data = await resp.json();
        
        btn.classList.remove('uploading');
        btn.textContent = '🧠 2nd Brain';
        
        if (data.deep_tutor_uploaded) {
            const words = data.word_count || 0;
            toast(`Sent to Second Brain — ${words} words indexed`, 'info');
        } else if (data.error) {
            toast('Upload failed: ' + data.error, 'error');
        } else {
            toast('Text extracted but KB upload failed — check DeepTutor', 'error');
        }
    } catch(e) {
        btn.classList.remove('uploading');
        btn.textContent = '🧠 2nd Brain';
        toast('Second Brain unreachable: ' + e.message, 'error');
    }
}

