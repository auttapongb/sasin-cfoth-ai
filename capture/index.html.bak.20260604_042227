async function sendChatV2() {
    const input = document.getElementById('chatInput');
    const btn = document.getElementById('chatSendBtn');
    const question = input.value.trim();
    if (!question) return;
    input.value = ''; input.disabled = true; btn.disabled = true;
    const msgs = document.getElementById('chatMessages');
    msgs.innerHTML += '<div class="chat-msg user">'+escapeHtml(question)+'</div>';
    const aiDiv = document.createElement('div');
    aiDiv.className = 'chat-msg ai'; aiDiv.textContent = '▌';
    msgs.appendChild(aiDiv);
    try {
        const answer = await streamApi('/chat/v2', {session_id: sessionId, question}, (token, full) => {
            aiDiv.textContent = full + '▌';
            msgs.scrollTop = msgs.scrollHeight;
        });
        aiDiv.textContent = answer;
        aiDiv.innerHTML = markedToHtml(answer);
    } catch(e) {
        aiDiv.textContent = 'Error: ' + e.message;
    }
    input.disabled = false; btn.disabled = false;
    input.focus();
}

// ═══ HELPERS ═══
function escapeHtml(s) {
    if (!s) return '';
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
}
function markedToHtml(md) {
    if (!md) return '';
    return md.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
        .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
        .replace(/\*(.+?)\*/g,'<em>$1</em>')
        .replace(/^### (.+)$/gm,'<h4 style="color:var(--gold);margin:12px 0 4px;">$1</h4>')
        .replace(/^## (.+)$/gm,'<h3 style="color:var(--gold);margin:14px 0 6px;">$1</h3>')
        .replace(/^# (.+)$/gm,'<h2 style="color:var(--gold);margin:16px 0 8px;">$1</h2>')
        .replace(/^- (.+)$/gm,'<li>$1</li>')
        .replace(/\n\n/g,'<br><br>');
}



