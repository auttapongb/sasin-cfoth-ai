// Override chat send to use v2 when on chat tab
const _origSendChat = sendChat;
sendChat = function() {
    // Try v2 first for citation-aware responses, fall back to v1 on error
    const input = document.getElementById('chatInput');
    const question = input.value.trim();
    if (!question) return;
    
    // Use original (non-streaming) sendChat if we know v2 has issues
    // or try v2 and fallback. For now, use original which is more reliable.
    return _origSendChat();
};

