// ─── Second Brain Graph ─────────────────────────
let brainSim = null;

function initBrainGraph() {
    // Ensure SVG parent is visible and has dimensions
    const container = document.getElementById('brainGraphView');
    if (container) {
        container.style.display = 'block';
        // Force layout recalculation
        void container.offsetHeight;
    }
    const svgEl = document.getElementById('brainGraph');
    if (!svgEl) return;
    
    // Explicitly set SVG size from container or viewport
    const W = Math.max(container?.clientWidth || window.innerWidth - 40, 400);
    const H = Math.max(container?.clientHeight || window.innerHeight - 200, 400);
    svgEl.setAttribute('width', W);
    svgEl.setAttribute('height', H);
    svgEl.style.width = W + 'px';
    svgEl.style.height = H + 'px';
    
    fetch(API + '/second-brain/graph')
        .then(r => r.json())
        .then(graphData => {
            if (!graphData.nodes || !graphData.nodes.length) return;
            renderBrainGraph(graphData, W, H);
            document.getElementById('brainStats').textContent = 
                `${graphData.nodes.filter(n=>n.group==='doc').length} docs · ${graphData.nodes.filter(n=>n.group==='framework').length} frameworks · ${graphData.nodes.filter(n=>n.group==='topic').length} topics · ${(graphData.links||[]).filter(l=>l.type==='related').length} cross-links`;
        })
        .catch(e => console.error('Brain graph fetch error:', e));
}

function renderBrainGraph(data, W, H) {
    const svg = d3.select('#brainGraph');
    svg.selectAll('*').remove();
    svg.attr('viewBox', `0 0 ${W} ${H}`).attr('preserveAspectRatio', 'xMidYMid meet');
    const g = svg.append('g');
    svg.call(d3.zoom().scaleExtent([0.1, 4]).on('zoom', (e) => g.attr('transform', e.transform)));

    const colors = { doc: '#818cf8', framework: '#60a5fa', topic: '#4ade80' };
    const sim = d3.forceSimulation(data.nodes)
        .force('link', d3.forceLink(data.links).id(d => d.id).distance(100))
        .force('charge', d3.forceManyBody().strength(-180))
        .force('center', d3.forceCenter(W/2, H/2))
        .force('collision', d3.forceCollide().radius(25));
    brainSim = sim;

    const link = g.append('g').selectAll('line')
        .data(data.links).join('line')
        .attr('stroke', d => d.type === 'related' ? 'rgba(251,191,36,0.2)' : 'rgba(148,163,184,0.12)')
        .attr('stroke-width', d => d.type === 'related' ? 1.2 : 0.6)
        .attr('stroke-dasharray', d => d.type === 'related' ? '3,2' : 'none');

    const node = g.append('g').selectAll('g')
        .data(data.nodes).join('g').attr('class','brain-node').style('cursor','pointer')
        .call(d3.drag().on('start',(e,d)=>{if(!e.active)sim.alphaTarget(0.3).restart();d.fx=d.x;d.fy=d.y;})
            .on('drag',(e,d)=>{d.fx=e.x;d.fy=e.y;})
            .on('end',(e,d)=>{if(!e.active)sim.alphaTarget(0);d.fx=null;d.fy=null;}));

    node.append('circle').attr('r', d => d.group==='doc' ? Math.max(5,Math.min(16,(d.size||100)/200)) : 7)
        .attr('fill', d => colors[d.group]||'#64748b').attr('stroke','#1e293b').attr('stroke-width',1.5);

    node.append('text').text(d => (d.title||'').length > 22 ? d.title.slice(0,22)+'…' : d.title||'')
        .attr('dx',10).attr('dy',4).attr('fill','#94a3b8').attr('font-size','10px');

    node.on('click', (e, d) => showBrainDetail(d, data));
    node.on('mouseenter', (e, d) => {
        const connected = new Set();
        data.links.forEach(l => { if(l.source.id===d.id||l.target.id===d.id) connected.add(l.source.id===d.id?l.target.id:l.source.id); });
        node.style('opacity', n => connected.has(n.id)||n.id===d.id ? 1 : 0.15);
        link.style('opacity', l => l.source.id===d.id||l.target.id===d.id ? 0.7 : 0.03);
    });
    node.on('mouseleave', () => { node.style('opacity',1); link.style('opacity', d => d.type==='related'?0.3:0.5); });

    sim.on('tick', () => {
        link.attr('x1',d=>d.source.x).attr('y1',d=>d.source.y).attr('x2',d=>d.target.x).attr('y2',d=>d.target.y);
        node.attr('transform', d => `translate(${d.x},${d.y})`);
    });
}

