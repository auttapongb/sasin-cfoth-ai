function takeQuiz(quiz) {
    _currentQuiz = quiz;
    const taker = document.getElementById('quizTaker');
    taker.style.display = 'block';
    document.getElementById('quizList').style.display = 'none';
    let html = '<h3 style="color:var(--gold);margin-bottom:12px;">'+escapeHtml(quiz.title)+'</h3>';
    quiz.questions.forEach((q, i) => {
        html += '<div style="margin-bottom:16px;padding:12px;background:var(--bg);border:1px solid var(--border);border-radius:8px;">';
        html += '<div style="font-weight:600;margin-bottom:8px;">'+(i+1)+'. '+escapeHtml(q.q)+'</div>';
        if (q.choices) {
            q.choices.forEach(c => { html += '<label style="display:block;padding:4px 0;font-size:0.85rem;cursor:pointer;"><input type="radio" name="q'+i+'" value="'+c.charAt(0)+'"> '+escapeHtml(c)+'</label>'; });
        } else {
            html += '<input type="text" id="sa'+i+'" placeholder="Your answer..." style="width:100%;background:var(--card);border:1px solid var(--border);color:var(--text);padding:8px;border-radius:8px;font-size:0.85rem;">';
        }
        html += '</div>';
    });
    html += '<button class="btn-sm primary" onclick="submitQuiz()" style="margin-top:12px;">Submit Answers</button>';
    html += '<button class="btn-sm" onclick="document.getElementById(\'quizTaker\').style.display=\'none\';document.getElementById(\'quizList\').style.display=\'\';" style="margin-left:8px;">Cancel</button>';
    taker.innerHTML = html;
}
async function submitQuiz() {
    if (!_currentQuiz) return;
    const answers = [];
    _currentQuiz.questions.forEach((q, i) => {
        const radio = document.querySelector('input[name="q'+i+'"]:checked');
        if (radio) answers.push({question_idx:i, answer:radio.value});
        else {
            const sa = document.getElementById('sa'+i);
            if (sa) answers.push({question_idx:i, answer:sa.value});
        }
    });
    try {
        const result = await api('/quizzes/'+_currentQuiz.id+'/submit', {method:'POST',body:JSON.stringify({answers})});
        let html = '<h3 style="color:var(--gold);margin-bottom:12px;">Results: '+result.score+'%</h3>';
        html += '<div style="font-size:1.5rem;text-align:center;margin:16px 0;color:'+(result.score>=70?'var(--success)':'var(--recording)')+'">'+result.correct+'/'+result.total+' correct</div>';
        if (result.corrections && result.corrections.length) {
            html += '<div style="margin-top:12px;"><strong>Review:</strong></div>';
            result.corrections.forEach(c => {
                html += '<div style="padding:8px;margin:4px 0;background:rgba(232,93,58,0.1);border:1px solid rgba(232,93,58,0.2);border-radius:8px;font-size:0.85rem;">';
                html += '<strong>Q'+(c.question_idx+1)+':</strong> Your answer: '+escapeHtml(c.your_answer)+' → Correct: '+escapeHtml(c.correct_answer);
                if (c.explanation) html += '<br><span style="color:var(--dim)">'+escapeHtml(c.explanation)+'</span>';
                html += '</div>';
            });
        }
        html += '<button class="btn-sm" onclick="document.getElementById(\'quizTaker\').style.display=\'none\';document.getElementById(\'quizList\').style.display=\'\';loadQuizzes();" style="margin-top:12px;">Back to Quizzes</button>';
